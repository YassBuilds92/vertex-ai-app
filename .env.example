# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# TAVILY_API_KEY: Optional but recommended for deterministic Cowork web search.
# Keep the real key only in local/deployed secrets, never in tracked files.
TAVILY_API_KEY=""

# ALLOW_PUBLIC_SEARCH_FALLBACKS: Optional emergency fallback for public search engines.
# Default should remain false so Cowork prefers Tavily, then trusted direct sources.
ALLOW_PUBLIC_SEARCH_FALLBACKS="false"

# LATEX_RENDER_PROVIDER: External LaTeX renderer used by Cowork for premium/thematic PDFs.
# Supported: ytotech, latexonline. Default runtime fallback is ytotech-compatible.
LATEX_RENDER_PROVIDER="ytotech"

# LATEX_RENDER_BASE_URL: Optional override for the external LaTeX renderer base URL.
# Example: https://latex.ytotech.com
LATEX_RENDER_BASE_URL=""

# LATEX_RENDER_TIMEOUT_MS: Timeout for external LaTeX compilation requests.
LATEX_RENDER_TIMEOUT_MS="30000"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VERTEX_PROJECT_ID: Your Google Cloud Project ID for Vertex AI
VERTEX_PROJECT_ID=""

# VERTEX_LOCATION: Your Google Cloud Region for Vertex AI
VERTEX_LOCATION=""

# LYRIA_LOCATION: Optional override for Lyria 2 generation if it differs from VERTEX_LOCATION.
# Example: us-central1
LYRIA_LOCATION=""

# VERTEX_GCS_OUTPUT_URI: GCS bucket for video generation output (e.g., gs://my-bucket/output)
VERTEX_GCS_OUTPUT_URI=""

# GOOGLE_APPLICATION_CREDENTIALS_JSON: Your Service Account JSON key
GOOGLE_APPLICATION_CREDENTIALS_JSON=""
