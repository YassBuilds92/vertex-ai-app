# Ce projet utilise uniquement Vertex AI avec `gcloud auth application-default login`.
# Ne pas utiliser `GEMINI_API_KEY` ni `VERTEX_EXPRESS` ici.
# Setup local recommande:
#   gcloud config set project <VERTEX_PROJECT_ID>
#   gcloud auth application-default login

# TAVILY_API_KEY: Optional but recommended for deterministic Cowork web search.
# Keep the real key only in local/deployed secrets, never in tracked files.
TAVILY_API_KEY=""

# ALLOW_PUBLIC_SEARCH_FALLBACKS: Optional emergency fallback for public search engines.
# Default should remain false so Cowork prefers Tavily, then trusted direct sources.
ALLOW_PUBLIC_SEARCH_FALLBACKS="false"

# LATEX_RENDER_PROVIDER: External LaTeX renderer used by Cowork for premium/thematic PDFs.
# Supported: ytotech, latexonline. Default runtime fallback is ytotech-compatible.
LATEX_RENDER_PROVIDER="ytotech"

# LATEX_RENDER_BASE_URL: Optional override for the external LaTeX renderer base URL.
# Example: https://latex.ytotech.com
LATEX_RENDER_BASE_URL=""

# LATEX_RENDER_TIMEOUT_MS: Timeout for external LaTeX compilation requests.
LATEX_RENDER_TIMEOUT_MS="30000"

# APP_URL: URL publique ou locale de l'application.
# Utilisee pour les callbacks OAuth, les liens internes et certains endpoints.
APP_URL="http://127.0.0.1:3000"

# VERTEX_PROJECT_ID: Google Cloud project ID utilise par Vertex AI.
VERTEX_PROJECT_ID="your-gcp-project-id"

# VERTEX_LOCATION: region Vertex AI par defaut.
# Garder `us-central1` sauf besoin contraire explicite.
VERTEX_LOCATION="us-central1"

# LYRIA_LOCATION: Optional override for Lyria 2 generation if it differs from VERTEX_LOCATION.
# Example: us-central1
LYRIA_LOCATION=""

# VERTEX_GCS_OUTPUT_URI: bucket + prefix GCS utilises pour les sorties video
# et pour les uploads runtime du backend.
VERTEX_GCS_OUTPUT_URI="gs://your-bucket/output"

# GOOGLE_APPLICATION_CREDENTIALS_JSON: override optionnel.
# Laisser vide en dev normal pour utiliser ADC / `gcloud auth application-default login`.
GOOGLE_APPLICATION_CREDENTIALS_JSON=""
