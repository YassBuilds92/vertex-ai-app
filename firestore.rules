rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}/sessions
    // Document ID: {sessionId}
    // Fields:
    //   - title: string (required) - conversation title
    //   - mode: string (required) - session mode
    //   - updatedAt: number (required) - timestamp
    //   - userId: string (required) - owner UID
    //
    // Collection: /users/{userId}/sessions/{sessionId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - role: string (required) - user or model
    //   - content: string (required) - text content
    //   - thoughts: string (optional) - model thoughts
    //   - attachments: list (optional) - attachments
    //   - createdAt: number (required) - timestamp
    //   - sessionId: string (required) - parent session ID
    //   - userId: string (required) - owner UID
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "yayaben92y@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, maxLen) {
      return request.resource.data[field] is string && request.resource.data[field].size() <= maxLen;
    }

    function isValidNumber(field) {
      return request.resource.data[field] is number;
    }

    function isValidList(field, maxLen) {
      return !(field in request.resource.data) || (request.resource.data[field] is list && request.resource.data[field].size() <= maxLen);
    }

    function isValidCoworkRunState(data) {
      return !('runState' in data) || (data.runState is string && data.runState in ['running', 'completed', 'failed', 'aborted']);
    }

    function isValidCoworkRunMeta(data) {
      return !('runMeta' in data) || (
        data.runMeta is map &&
        data.runMeta.keys().hasOnly([
          'iterations',
          'modelCalls',
          'toolCalls',
          'webSearches',
          'webFetches',
          'retryCount',
          'queueWaitMs',
          'inputTokens',
          'outputTokens',
          'thoughtTokens',
          'toolUseTokens',
          'totalTokens',
          'estimatedCostUsd',
          'estimatedCostEur'
        ]) &&
        (!('iterations' in data.runMeta) || data.runMeta.iterations is number) &&
        (!('modelCalls' in data.runMeta) || data.runMeta.modelCalls is number) &&
        (!('toolCalls' in data.runMeta) || data.runMeta.toolCalls is number) &&
        (!('webSearches' in data.runMeta) || data.runMeta.webSearches is number) &&
        (!('webFetches' in data.runMeta) || data.runMeta.webFetches is number) &&
        (!('retryCount' in data.runMeta) || data.runMeta.retryCount is number) &&
        (!('queueWaitMs' in data.runMeta) || data.runMeta.queueWaitMs is number) &&
        (!('inputTokens' in data.runMeta) || data.runMeta.inputTokens is number) &&
        (!('outputTokens' in data.runMeta) || data.runMeta.outputTokens is number) &&
        (!('thoughtTokens' in data.runMeta) || data.runMeta.thoughtTokens is number) &&
        (!('toolUseTokens' in data.runMeta) || data.runMeta.toolUseTokens is number) &&
        (!('totalTokens' in data.runMeta) || data.runMeta.totalTokens is number) &&
        (!('estimatedCostUsd' in data.runMeta) || data.runMeta.estimatedCostUsd is number) &&
        (!('estimatedCostEur' in data.runMeta) || data.runMeta.estimatedCostEur is number)
      );
    }

    function isValidCoworkActivity(data) {
      return !('activity' in data) || (data.activity is list && data.activity.size() <= 80);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidSession(data) {
      return hasRequiredFields(['title', 'mode', 'updatedAt', 'userId']) &&
             hasOnlyAllowedFields(['title', 'mode', 'updatedAt', 'userId', 'systemInstruction', 'systemPromptHistory']) &&
             data.title is string && data.title.size() <= 200 &&
             data.mode is string && data.mode.size() <= 50 &&
             data.updatedAt is number &&
             data.userId == request.auth.uid &&
             (!('systemInstruction' in data) || (data.systemInstruction is string && data.systemInstruction.size() <= 20000)) &&
             (!('systemPromptHistory' in data) || (data.systemPromptHistory is list));
    }

    function isValidMessage(data) {
      return hasRequiredFields(['role', 'content', 'createdAt', 'sessionId', 'userId']) &&
             // On remplace 'image' par 'images' et on ajoute 'thoughtImages'
             hasOnlyAllowedFields(['id', 'role', 'content', 'thoughts', 'attachments', 'createdAt', 'sessionId', 'userId', 'video', 'audio', 'images', 'thoughtImages', 'refinedInstruction', 'activity', 'runState', 'runMeta']) &&
             data.role in ['user', 'model'] &&
             // On augmente la limite de 50 000 à 500 000 caractères
             data.content is string && data.content.size() <= 500000 &&
             (!( 'thoughts' in data) || (data.thoughts is string && data.thoughts.size() <= 500000)) &&
             isValidList('attachments', 20) &&
             isValidCoworkActivity(data) &&
             isValidCoworkRunState(data) &&
             isValidCoworkRunMeta(data) &&
             data.createdAt is number &&
             data.sessionId is string &&
             data.userId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /sessions/{sessionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidSession(request.resource.data);
        allow update: if isOwner(userId) && isValidSession(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();

        match /messages/{messageId} {
          allow read: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId) && isValidMessage(request.resource.data);
          allow update: if isOwner(userId) && isValidMessage(request.resource.data);
          allow delete: if isOwner(userId) || isAdmin();
        }
      }

      match /custom_prompts/{promptId} {
        allow read, write: if isOwner(userId) || isAdmin();
        
        function isValidCustomPrompt(data) {
          return hasRequiredFields(['title', 'prompt', 'createdAt', 'userId']) &&
                 data.userId == request.auth.uid;
        }

        allow create: if isOwner(userId) && isValidCustomPrompt(request.resource.data);
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
